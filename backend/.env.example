# Server
PORT=4000
APP_ENV=development
BASE_URL=http://localhost:4000
JWT_SECRET=zuri-dev-secret-change-in-production
BCRYPT_COST=12

# Demo mode runs without Postgres/Redis/Monnify/AI keys.
# Set DEMO_MODE=false and fill keys below for real integrations.
DEMO_MODE=true
MONNIFY_WALLET_ACCOUNT=
# Monnify (sandbox)
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=https://sandbox.monnify.com
WEBHOOK_URL=http://localhost:4000/webhooks/monnify

# AI (priority: Anthropic → GitHub Models → OpenAI → demo reasoner)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# GitHub Models (free with any GitHub account — https://github.com/marketplace/models)
GITHUB_AI_API_KEY=
GITHUB_AI_MODEL=gpt-4o-mini
GITHUB_AI_BASE_URL=https://models.inference.ai.azure.com

# Optional managed services (unused in DEMO_MODE)
DATABASE_URL=
REDIS_URL=
